# ============================================================
# MornDigest - 环境变量配置模板
# 使用说明：
#   1. 复制本文件为 .env ：cp .env.example .env
#   2. 填入真实的 API Key
#   3. .env 已在 .gitignore 中，不会提交到版本库
# ============================================================

# --- 外部 API Key ---
# 和风天气 API Key (https://console.qweather.com/)
QWEATHER_KEY=

# 新闻 API Key (请按实际使用的新闻服务填写)
NEWS_KEY=

# --- AI 大模型 API Key ---
# DeepSeek API Key (https://platform.deepseek.com/)
DEEPSEEK_KEY=

# 智谱AI API Key (https://open.bigmodel.cn/)
ZHIPU_KEY=

# 通义千问 API Key (https://dashscope.console.aliyun.com/)
QWEN_KEY=

# --- 应用配置 ---
# 默认城市
DEFAULT_CITY=北京

# 默认 AI 模型: deepseek / zhipu / qwen
DEFAULT_MODEL=deepseek

# 默认新闻分类 (逗号分隔)
DEFAULT_CATEGORIES=科技,综合

# 数据存储后端: json / sqlite
STORAGE_BACKEND=json

# 应用语言: zh-CN / en-US
APP_LANG=zh-CN